@\n+import {\n+  CallHandler,\n+  ExecutionContext,\n+  Injectable,\n+  NestInterceptor,\n+} from '@nestjs/common';\n+import { Observable } from 'rxjs';\n+import { map } from 'rxjs/operators';\n+\n+export interface ResponseEnvelope<T> {\n+  data: T;\n+  meta?: Record<string, unknown>;\n+}\n+\n+@Injectable()\n+export class ResponseEnvelopeInterceptor<T>\n+  implements NestInterceptor<T, ResponseEnvelope<T>>\n+{\n+  intercept(\n+    _context: ExecutionContext,\n+    next: CallHandler<T>,\n+  ): Observable<ResponseEnvelope<T>> {\n+    return next.handle().pipe(\n+      map((value) => {\n+        if (isResponseEnvelope(value)) {\n+          return value;\n+        }\n+\n+        return {\n+          data: value,\n+        };\n+      }),\n+    );\n+  }\n+}\n+\n+function isResponseEnvelope<T>(value: T): value is ResponseEnvelope<unknown> {\n+  return (\n+    typeof value === 'object' &&\n+    value !== null &&\n+    'data' in value &&\n+    !Array.isArray(value)\n+  );\n+}\ndiff --git a/C:/smoke/clean/apps/api/src/common/pipes/query-normalization.pipe.spec.ts b/C:/smoke/clean/apps/api/src/common/pipes/query-normalization.pipe.spec.ts\nnew file mode 100644\nindex 0000000000000000000000000000000000000000..7d242e774388e501c8a7d31cfd5b48ca6f3a4055\n--- /dev/null\n+++ b/C:/smoke/clean/apps/api/src/common/pipes/query-normalization.pipe.spec.ts\n@@ -0,0 +1,42 @@\n+import { ArgumentMetadata } from '@nestjs/common';\n+import { QueryNormalizationPipe } from './query-normalization.pipe';\n+\n+describe('QueryNormalizationPipe', () => {\n+  const pipe = new QueryNormalizationPipe();\n+  const metadata: ArgumentMetadata = {\n+    type: 'query',\n+    metatype: Object,\n+    data: '',\n+  };\n+\n+  it('converts snake_case query keys to camelCase', () => {\n+    expect(\n+      pipe.transform(\n+        {\n+          created_at: '2026-01-01',\n+          page_size: '20',\n+        },\n+        metadata,\n+      ),\n+    ).toEqual({\n+      createdAt: '2026-01-01',\n+      pageSize: '20',